pipeline {

 agent any

 tools {
  allure 'allure'
 }

 parameters {

  choice(
   name: 'ENV',
   choices: ['dev','staging'],
   description: 'Select Environment'
  )

  choice(
   name: 'TEST_TYPE',
   choices: ['smoke','regression','e2e'],
   description: 'Select Test Suite'
  )

 }

 stages {

  stage('Install Dependencies') {
   steps {
    dir('automation') {
     sh 'npm install'
     sh 'npx playwright install'
    }
   }
  }

  stage('Start Express Server') {
   steps {
    dir('app/server') {
     sh '''
     npm install
     node server.js &
     '''
    }
   }
  }

  stage('Start React Client') {
   steps {
    dir('app/client') {
     sh '''
     npm install
     npm start &
     '''
    }
   }
  }

  stage('Wait for Services') {
   steps {
    sh '''
    echo "Waiting for services..."
    sleep 15
    '''
   }
  }

  stage('Clean Reports') {
   steps {
    dir('automation') {
     sh 'rm -rf allure-results allure-report'
    }
   }
  }

  stage('Run Tests') {
   steps {
    dir('automation') {
     sh """
     export TEST_ENV=${params.ENV}
     npx playwright test tests/${params.TEST_TYPE} --reporter=list,html,allure-playwright
     """
    }
   }
  }

  stage('Generate Allure Report') {
   steps {
    dir('automation') {
     allure includeProperties: false,
            jdk: '',
            results: [[path: 'allure-results']]
    }
   }
  }

  stage('Archive Playwright Report') {
   steps {
    dir('automation') {
     archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true
    }
   }
  }

 }

}